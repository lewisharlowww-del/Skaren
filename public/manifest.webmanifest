{
  "name": "Skaren",
  "short_name": "Skaren",
  "description": "Scan smarter. Live cleaner. Clear product grades, additives, allergens, and nutrition insights for Norwegian grocery shelves.",
  "id": "/",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#F0F7F2",
  "theme_color": "#1A5C3A",
  "categories": ["food", "health", "shopping", "lifestyle"],
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png"
    },
    {
