  "shortcuts": [
    {
      "name": "Scan product",
      "short_name": "Scan",
      "description": "Open Skaren directly to the barcode scanner.",
      "url": "/scan?source=shortcut",
      "icons": [{ "src": "/icons/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Scan history",
      "short_name": "History",
      "description": "Review saved product scans.",
      "url": "/history?source=shortcut",
      "icons": [{ "src": "/icons/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Stats",
      "short_name": "Stats",
      "description": "Open your Skaren overview.",
